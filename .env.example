NODE_ENV=production
PORT=3000
APP_URL=https://news.example.com
FORCE_HTTPS=true

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/namo_bharat_news24
REDIS_URL=redis://redis:6379

SESSION_SECRET=change-this-long-random-value
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Use-A-Long-Unique-Random-Password!

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

PGPOOL_MAX=12

REQUIRE_EXPLICIT_ADMIN_PASSWORD=true
REQUEST_TIMEOUT_MS=15000
MAX_JSON_BODY=256kb
